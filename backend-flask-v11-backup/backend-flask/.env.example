# ====================================================================
# ForecastIQ — Variables d'environnement
# Copier ce fichier en .env et adapter
# ====================================================================

# Base de données PostgreSQL
# Sur Mac Homebrew par défaut, ton user système a accès sans mot de passe :
DATABASE_URL=postgresql://localhost/forecastiq

# Si tu as un mot de passe Postgres :
# DATABASE_URL=postgresql://malak:tonpassword@localhost:5432/forecastiq

# JWT — IMPORTANT : changer en production !
JWT_SECRET_KEY=dev-secret-change-me-please-very-long-random-string

# Admin par défaut (créé au premier lancement de init_db.py)
ADMIN_EMAIL=admin@forecastiq.com
ADMIN_PASSWORD=Admin@2026

# Serveur
PORT=3001
FLASK_DEBUG=1
