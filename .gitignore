# ====================================
# SECRETS (NE JAMAIS PUSHER)
# ====================================
backend-flask/.env
backend-flask/.env.local
backend-flask/.env.production
frontend/.env.local
frontend/.env.development.local
frontend/.env.production.local

# ====================================
# DEPENDANCES (téléchargeables)
# ====================================
backend-flask/venv/
backend-flask/.venv/
backend-flask/__pycache__/
backend-flask/**/__pycache__/
backend-flask/*.pyc
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/package-lock.json

# ====================================
# BASE DE DONNÉES & FICHIERS UPLOADÉS
